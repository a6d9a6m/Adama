datadir="/var/lib/proxysql"

admin_variables=
{
  admin_credentials="admin:admin"
  mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
  threads=4
  max_connections=2048
  default_query_delay=0
  default_query_timeout=36000000
  interfaces="0.0.0.0:6033"
  monitor_username="root"
  monitor_password="Root@123456"
}

mysql_servers =
(
  { address="mysql"         , port=3306, hostgroup=10, max_connections=200 },
  { address="mysql-replica" , port=3306, hostgroup=20, max_connections=200 }
)

mysql_users:
(
  { username = "root" , password = "Root@123456" , default_hostgroup = 10 , active = 1 }
)

mysql_replication_hostgroups=
(
  { writer_hostgroup=10 , reader_hostgroup=20 , check_type="read_only" }
)

mysql_query_rules:
(
  { rule_id=1, active=1, match_digest="^SELECT .*", destination_hostgroup=20, apply=1 },
  { rule_id=2, active=1, match_digest="^SELECT @@.*", destination_hostgroup=10, apply=1 }
)

scheduler=
(
)

mysql-monitor_username="root"
mysql-monitor_password="Root@123456"
